<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Saoirse Mahon Portfolio</title>

  <!-- Editorial + clean girl font pairing -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=Inter:wght@300;400&display=swap" rel="stylesheet">

  <style>
    body {
      margin: 0;
      font-family: 'Inter', sans-serif;
      background-color: #FFEBED;
      color: #27153D;
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 30px 50px;
    }

    .title h1 {
      margin: 0;
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      font-weight: 500;
      letter-spacing: 0.5px;
    }

    .title p {
      margin: 4px 0 0;
      font-size: 13px;
      color: #3E2E4A;
      font-weight: 300;
    }

    nav a {
      margin-left: 30px;
      text-decoration: none;
      color: #27153D;
      font-size: 14px;
      transition: transform 0.2s ease, opacity 0.2s ease;
      display: inline-block;
    }

    nav a:hover {
      transform: scale(1.08);
      opacity: 0.7;
    }

    nav a:active {
      transform: scale(1.2);
    }

    section {
      padding: 100px 50px;
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s ease;
    }

    section.visible {
      opacity: 1;
      transform: translateY(0);
    }

    h2 {
      font-family: 'Playfair Display', serif;
      font-weight: 400;
      margin-bottom: 20px;
    }

    #works {
      text-align: center;
    }

    .works-grid {
      display: flex;
      justify-content: center;
      gap: 60px;
      margin-top: 40px;
      flex-wrap: wrap;
    }

    .work-item img {
      width: 220px;
      height: 220px;
      object-fit: cover;
      border-radius: 16px;
      transition: transform 0.4s ease;
    }

    .work-item img:hover {
      transform: scale(1.06);
    }

    .work-item a {
      text-decoration: none;
      color: #27153D;
      display: block;
      margin-top: 12px;
      font-size: 14px;
    }

    footer {
      padding: 50px;
      text-align: center;
      border-top: 1px solid #F6B6B7;
      font-weight: 300;
      background-color: #F6B6B7;
      color: #27153D;
    }
  </style>
</head>
<body>

  <header>
    <div class="title">
      <h1>Saoirse Mahon</h1>
      <p>Media Practitioner</p>
    </div>

    <nav>
      <a href="#home">Home</a>
      <a href="#about">About Me</a>
      <a href="#works">Works</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <section id="home">
    <h2>Home</h2>
  </section>

  <section id="about">
    <h2>About Me</h2>
    <p>Write about yourself here.</p>
  </section>

  <section id="works">
    <h2>Works</h2>
    <div class="works-grid">
      <div class="work-item">
        <img src="photo1.jpg" alt="Photography">
        <a href="photography.html">Photography</a>
      </div>
      <div class="work-item">
        <img src="photo2.jpg" alt="Video">
        <a href="video.html">Video</a>
      </div>
      <div class="work-item">
        <img src="photo3.jpg" alt="Other Works">
        <a href="other.html">Other Works</a>
      </div>
    </div>
  </section>

  <section id="contact">
    <h2>Contact</h2>
    <p>Your contact info here.</p>
  </section>

  <footer>
    <h3>Social Media</h3>
    <p>Add your social links here.</p>
  </footer>

  <script>
    const sections = document.querySelectorAll('section');

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.2 });

    sections.forEach(section => {
      observer.observe(section);
    });
  </script>

</body>
</html>
